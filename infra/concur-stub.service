[Unit]
Description=SAP Concur Stub (Layer 3) — FastAPI SQLite mock API
After=network.target

[Service]
User=itzuser
WorkingDirectory=/home/itzuser/concur-from-github/concur-stub
EnvironmentFile=/home/itzuser/concur-from-github/concur-stub/.env
ExecStart=/home/itzuser/concur-from-github/concur-stub/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8001
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
