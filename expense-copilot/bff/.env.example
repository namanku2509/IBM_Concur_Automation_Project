# ── Copy this file to .env and fill in your values ──────────────────────────
PORT=4000

# URLs pointing to Layer 2 and Layer 3
LAYER2_BASE_URL=http://localhost:8000
LAYER3_BASE_URL=http://localhost:8001

# CORS — set to your frontend origin
CORS_ORIGIN=http://localhost:3000
# On VM: CORS_ORIGIN=http://169.60.30.246

# Session secret — change this to something random in production
SESSION_SECRET=change-me-to-something-random

# ── watsonx Orchestrate Chat Loader ──────────────────────────────────────────
# Copy these values from your WXO embed snippet:
#   wxOConfiguration.orchestrationID
#   wxOConfiguration.hostURL            (e.g. https://au-syd.watson-orchestrate.cloud.ibm.com)
#   wxOConfiguration.crn
#   wxOConfiguration.chatOptions.agentId
#   wxOConfiguration.chatOptions.agentEnvironmentId
WXO_ORCHESTRATION_ID=
WXO_HOST_URL=
WXO_CRN=
WXO_AGENT_ID=
WXO_AGENT_ENVIRONMENT_ID=

# IBM Cloud API key — used by BFF to get IAM token for WXO widget auth
WXO_IBM_API_KEY=
