# ── Copy this file to .env and fill in your values ──────────────────────────
PORT=4000

# Node environment — set to 'production' on the VM to enable HTTPS-only cookies
NODE_ENV=development

# URLs pointing to Layer 2 and Layer 3
LAYER2_BASE_URL=http://localhost:8000
LAYER3_BASE_URL=http://localhost:8001

# CORS — set to your frontend origin
CORS_ORIGIN=http://localhost:3000
# On VM: CORS_ORIGIN=http://169.60.30.246

# Session secret — change this to something random in production
SESSION_SECRET=change-me-to-something-random

# watsonx Orchestrate embedded agent.
# Prerequisites:
#   1. Generate an RSA-2048 keypair:
#        openssl genrsa -out wxo_private.pem 2048
#        openssl rsa -in wxo_private.pem -pubout -out wxo_public.pem
#   2. Place wxo_private.pem at the project root (or set WXO_PRIVATE_KEY_PATH).
#   3. Paste the contents of wxo_public.pem into:
#        WXO Console → Settings → Embed Security → Add public key
#   4. Fill in the values below from the WXO Console.
#
# WXO_ORCHESTRATION_ID  — found in WXO Console → Environments → <env> → Embed
# WXO_HOST_URL          — your WXO service URL, e.g. https://us-south.assistant.watson.cloud.ibm.com
# WXO_CRN              — IBM Cloud CRN of the WXO instance
# WXO_AGENT_ID          — the agent's ID in WXO Console
# WXO_AGENT_ENVIRONMENT_ID — optional; the deployment environment ID (leave blank for default)
# WXO_ISSUER            — Issuer URI registered in WXO Embed Security (defaults to WXO_HOST_URL if unset)
# WXO_USER_SUB          — IBM Cloud IAM email used as the JWT subject in single-user / demo mode
# WXO_PRIVATE_KEY_PATH  — absolute path to wxo_private.pem (defaults to project root)
WXO_ORCHESTRATION_ID=
WXO_HOST_URL=
WXO_CRN=
WXO_AGENT_ID=
WXO_AGENT_ENVIRONMENT_ID=
WXO_ISSUER=
WXO_USER_SUB=
WXO_PRIVATE_KEY_PATH=
